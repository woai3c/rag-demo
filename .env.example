# ============================================================
# 完整 RAG 的生成模型配置
# ============================================================
# 只需选择一个厂商，并填写该厂商对应的 API Key。
# 可选值：deepseek | qwen | zhipu | moonshot | doubao | baidu | custom
#
# Embedding 不使用这些 API：本项目始终使用本地 ONNX 模型
# Xenova/multilingual-e5-small。只有用户问题和检索出的 Top-K 文档片段
# 会在“RAG 问答”时发送给所选 LLM 厂商。

LLM_PROVIDER=deepseek
# 整次 Agent Loop 的超时上限（毫秒），不是单次请求的实际耗时
LLM_TIMEOUT_MS=30000

# ONNX 模型缓存目录（可选）。留空时使用项目根目录 .cache/transformers
EMBEDDING_CACHE_DIR=

# -------------------- DeepSeek --------------------
# 官方文档：https://api-docs.deepseek.com/
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash

# -------------------- 阿里云百炼 / Qwen --------------------
# 中国内地标准 API Key 使用下方地址；其他地域请按百炼控制台修改 Base URL。
# 官方文档：https://help.aliyun.com/zh/model-studio/first-api-call-to-qwen
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_MODEL=qwen-plus

# -------------------- 智谱 GLM --------------------
# 官方文档：https://docs.bigmodel.cn/cn/api/introduction
ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_MODEL=glm-5.2

# -------------------- Kimi / Moonshot --------------------
# 官方文档：https://platform.kimi.com/docs/api/overview
MOONSHOT_API_KEY=
MOONSHOT_BASE_URL=https://api.moonshot.cn/v1
MOONSHOT_MODEL=kimi-k2.6

# -------------------- 火山方舟 / 豆包 --------------------
# DOUBAO_MODEL 通常填写方舟控制台创建的推理接入点 ID（ep-...），
# 或填写当前账号支持的模型 ID，以控制台为准。
# 官方文档：https://www.volcengine.com/docs/82379
DOUBAO_API_KEY=
DOUBAO_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
DOUBAO_MODEL=

# -------------------- 百度千帆 / ERNIE --------------------
# 官方文档：https://cloud.baidu.com/doc/qianfan-docs/s/qm8qxemze
BAIDU_API_KEY=
BAIDU_BASE_URL=https://qianfan.baidubce.com/v2
BAIDU_MODEL=ernie-4.5-turbo-32k

# -------------------- 其他 OpenAI 兼容服务 --------------------
# 当 LLM_PROVIDER=custom 时使用。三项都必须填写。
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=

# 服务端口（可选）
PORT=3001
